# ============================================
# TiDB Cloud MySQL 配置
# ============================================
# 请从 TiDB Cloud 控制台获取以下信息：
# 1. 登录 https://tidbcloud.com
# 2. 选择你的集群
# 3. 点击 "Connect" 获取连接信息

# 集群地址（Host）
DB_HOST=gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com

# 端口（TiDB Cloud 默认 4000）
DB_PORT=4000

# 用户名
DB_USER=your_username.root

# 密码
DB_PASSWORD=your_password

# 数据库名
DB_NAME=luckin_coffee

# 是否启用 SSL（TiDB Cloud 必须为 true）
DB_SSL=true

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_jwt_secret_key

# ============================================
# 服务端口
# ============================================
PORT=4001
